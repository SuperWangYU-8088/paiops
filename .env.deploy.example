# 依赖与基础镜像加速源。企业内网已有制品库时，请替换为企业可信地址。
DOCKER_HUB_MIRROR=m.daocloud.io/docker.io
MAVEN_MIRROR_URL=https://maven.aliyun.com/repository/public
NPM_REGISTRY=https://registry.npmmirror.com
GOPROXY=https://goproxy.cn,direct
ALPINE_MIRROR=https://mirrors.aliyun.com/alpine

# 复制为 .env 后必须替换所有 CHANGE_ME 值。该文件不能提交到仓库。
MYSQL_ROOT_PASSWORD=CHANGE_ME_LONG_MYSQL_PASSWORD
REDIS_PASSWORD=CHANGE_ME_LONG_REDIS_PASSWORD
MINIO_ACCESS_KEY=paiopsadmin
MINIO_SECRET_KEY=CHANGE_ME_LONG_MINIO_PASSWORD

# JWT 至少 32 个随机字符；PAIOPS_MASTER_KEY 用于 AES-GCM 凭证加密，部署后不可随意更换。
JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET_AT_LEAST_32_CHARS
PAIOPS_MASTER_KEY=CHANGE_ME_RANDOM_MASTER_KEY_AT_LEAST_32_CHARS
PAIOPS_WORKER_TOKEN=CHANGE_ME_RANDOM_INTERNAL_WORKER_TOKEN
PAIOPS_ALERT_WEBHOOK_TOKEN=CHANGE_ME_RANDOM_ALERT_WEBHOOK_TOKEN

APP_AUTH_DEFAULT_USERNAME=admin
APP_AUTH_DEFAULT_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# 仅填写 Runbook 确实需要访问的目标主机，支持 *.example.com，不建议使用 *。
PAIOPS_HTTP_ALLOWED_HOSTS=prometheus,loki,kubernetes.default.svc,localhost,127.0.0.1

PAIOPS_WORKER_CONCURRENCY=2
PAIOPS_HTTP_PORT=80
