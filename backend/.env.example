# 服务器配置
SERVER_PORT=8084

# 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=paiagent
MYSQL_USERNAME=root
MYSQL_PASSWORD=CHANGE_ME_MYSQL_PASSWORD

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO 配置
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=paiopsadmin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
MINIO_PUBLIC_URL=http://localhost:9000

# JWT 配置（必须修改！建议使用 32 字符以上的随机字符串）
JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET_AT_LEAST_32_CHARS

# 默认管理员账户（生产环境建议禁用或修改）
# 留空则禁用默认账户，必须通过注册功能创建账户
APP_AUTH_DEFAULT_USERNAME=admin
APP_AUTH_DEFAULT_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# OpenAI 配置（可选，节点配置可覆盖）
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
